              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "mlw1F",
              "name": "bioText",
              "fill": "#8b87a0",
              "content": "Red is the legendary Pokemon champion of the Kanto region. After defeating the Pokemon League, he retreated to the summit of Mt. Silver to make himself even stronger. Known for his quiet but determined personality, Red is considered the strongest trainer of all time.",
              "lineHeight": 1.7,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "0z40G",
          "name": "Lore",
          "width": "fill_container",
          "fill": "#13121a",
