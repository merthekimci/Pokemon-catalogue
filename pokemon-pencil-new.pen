                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "3fNqW",
                  "name": "bioText",
                  "fill": "#5a566e",
                  "content": "Charmander, kuyrugundaki alev ile tanınan bir Ates tipi Pokemon'dur. Dogdugu andan itibaren kuyrugunda yanan alev, yasam enerjisinin bir gostergesidir. Alev sogurse, bu Pokemon'un saglik durumunun kotulestigi anlamina gelir.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
